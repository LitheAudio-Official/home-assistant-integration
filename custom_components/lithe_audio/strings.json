      "user": {
        "title": "Set up Lithe Audio speaker",
        "description": "Enter the details for your Lithe Audio WiFi speaker. LS10 speakers (PRO2, V3, iO1) require TLS certificates.",
        "data": {
          "product":   "Speaker model",
          "host":      "IP address",
          "port":      "Port (default 7777)",
          "cert_path": "Certificate path (cert/client.pem) — LS10 only",
          "key_path":  "Key path (cert/client.key) — LS10 only"
        }
      },
      "zeroconf_confirm": {
        "title": "Lithe Audio speaker found",
        "description": "A Lithe Audio speaker was found at {host} ({name}). Select the speaker model and enter certificate paths if required.",
